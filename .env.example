# ---- Copy to .env.local (Node/Docker) or .dev.vars (Cloudflare) and fill in ----

# ---- Nebius Serverless AI (the only inference provider) ---------------------
# Token Factory (hosted, per-token, no GPU to manage):
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
# ...or a dedicated Serverless AI Endpoint you deployed: http://<endpoint_ip>/v1
NEBIUS_API_KEY=nebius-your-key
NEBIUS_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# ---- Database (Turso / libSQL) ----------------------------------------------
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# ---- Auth.js (NextAuth) — Google OAuth --------------------------------------
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
# Public URL of the deployed app (Cloudflare/Vercel/Docker host).
AUTH_URL=http://localhost:3000

# Shared demo login (username/password) for invited users — rotate freely.
DEMO_USERNAME=Tintin
DEMO_PASSWORD=Mobius9

# "Contact us for login details" form. Create a free form at https://formspree.io
# that emails bijoyr@trinfac.com, then paste its id (the part after /f/). If unset,
# the owner's form id is used as a non-secret default (Formspree ids are public).
NEXT_PUBLIC_FORMSPREE_ID=xlgkozzo

# ---- Batch job (jobs/batch-screen.ts) ---------------------------------------
# Space/comma-separated markets the Serverless AI Job screens.
MARKETS=IN US INTL
# Cap symbols screened per market (0 = whole universe). Set small for a cheap
# test run, e.g. MAX_SYMBOLS=3.
MAX_SYMBOLS=0
# screen_history rows written by the job are stored under this user id.
BATCH_USER_ID=batch

# ---- Legacy: HTTP ingest endpoint guard (optional) --------------------------
# Only needed if you still drive cache refresh via /api/ingest + GitHub Actions
# instead of the Nebius batch job.
INGEST_SECRET=shared-secret-for-api-ingest
