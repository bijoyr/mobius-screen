{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nse-screener",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-05-05",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  // Serves the Worker at the custom domain (Cloudflare auto-manages DNS + TLS).
  // The zone (trustfractals.com) must be in this Cloudflare account.
  "routes": [{ "pattern": "screener.trustfractals.com", "custom_domain": true }],
  "vars": {
    "NEBIUS_BASE_URL": "https://api.tokenfactory.nebius.com/v1",
    "NEBIUS_MODEL": "Qwen/Qwen3-30B-A3B-Instruct-2507",
    "NEXT_PUBLIC_FORMSPREE_ID": "xlgkozzo"
  }
  // Secrets (set via `wrangler secret put`): NEBIUS_API_KEY, TURSO_DATABASE_URL,
  // TURSO_AUTH_TOKEN, AUTH_SECRET, AUTH_GOOGLE_ID, AUTH_GOOGLE_SECRET, AUTH_URL,
  // INGEST_SECRET, DEMO_USERNAME, DEMO_PASSWORD.
}
